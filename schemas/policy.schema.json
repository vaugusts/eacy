{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eacy.local/schemas/policy.schema.json",
  "title": "ExecutionPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": ["policy_version", "defaults", "risk_model", "rules", "audit"],
  "properties": {
    "policy_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unknown_command", "unknown_executor"],
      "properties": {
        "unknown_command": { "type": "string", "enum": ["deny"] },
        "unknown_executor": { "type": "string", "enum": ["deny"] },
        "audit_log_path": { "type": "string" }
      }
    },
    "risk_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "medium", "high", "blocked"],
      "properties": {
        "low": { "$ref": "#/$defs/riskRule" },
        "medium": { "$ref": "#/$defs/riskRule" },
        "high": { "$ref": "#/$defs/riskRule" },
        "blocked": { "$ref": "#/$defs/riskRule" }
      }
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/policyRule" }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_fields"],
      "properties": {
        "required_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "redact_parameters": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "riskRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect", "allow_executors"],
      "properties": {
        "effect": {
          "type": "string",
          "enum": ["allow", "confirm", "deny"]
        },
        "allow_executors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "policyRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "applies_to", "effect"],
      "properties": {
        "rule_id": { "type": "string" },
        "applies_to": { "type": "string" },
        "effect": {
          "type": "string",
          "enum": ["allow", "confirm", "deny"]
        },
        "conditions": {
          "type": "object"
        }
      }
    }
  }
}
