{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eacy.local/schemas/automation.schema.json",
  "title": "WorkflowDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "workflow"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "trigger", "inputs", "steps", "outputs"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "trigger": { "type": "object" },
        "inputs": { "type": "object" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "action"],
            "properties": {
              "id": { "type": "string" },
              "action": { "type": "string" },
              "uses": { "type": "string" }
            }
          }
        },
        "outputs": { "type": "object" },
        "observability": { "type": "object" }
      }
    }
  }
}
